# ─── Credenciales FTP ───────────────────────────────────────────
# Host del servidor (dominio o IP)
FTP_HOST=segedu.chakuy.online

# Usuario FTP (normalmente el usuario de cPanel)
FTP_USER=usuario_ftp

# Contraseña FTP
FTP_PASS=tu_contraseña

# Puerto FTP (21 por defecto, 990 para FTPS implícito)
FTP_PORT=21

# Usar FTPS (true/false) — activa si el hosting soporta FTP seguro
FTP_SECURE=false

# ─── Rutas remotas ──────────────────────────────────────────────
# Ruta en el servidor donde vive el dist del frontend
REMOTE_FRONTEND=/public/dist

# Ruta en el servidor donde vive el src del backend
REMOTE_BACKEND=/src

# ─── Reinicio automático del servidor (opcional) ─────────────────
# Si tienes un endpoint de reinicio en el backend, ponlo aquí.
# Déjalo vacío para reiniciar manualmente.
RESTART_URL=
RESTART_TOKEN=
